# UiPath Cloud
UIPATH_ORG=your_org_name
UIPATH_TENANT=DefaultTenant
UIPATH_BASE_URL=https://staging.uipath.com
UIPATH_CLIENT_ID=your_external_app_client_id
UIPATH_CLIENT_SECRET=your_external_app_client_secret
UIPATH_FOLDER_ID=your_folder_id
UIPATH_TENANT_ID=your_tenant_id
TM_UI_URL=https://staging.uipath.com/{org}/{tenant}/testmanager_/{project_key}/testcases

# UiPath Test Manager
TEST_MANAGER_PROJECT_ID=your_test_manager_project_uuid
TEST_MANAGER_BASE_URL=https://staging.uipath.com/{org}/{tenant}/testmanager_/api/v2

# Coding Agent (Gemini)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Compliance Engine (Groq)
GROQ_API_KEY=your_groq_api_key

# Public tunnel (for UiPath Cloud → local backend)
NGROK_URL=https://your-ngrok-subdomain.ngrok-free.dev
